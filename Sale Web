<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LumoCart | Login</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:#0b1020;
      --card:#11182d;
      --card2:#151f39;
      --text:#eef2ff;
      --muted:#a7b0d6;
      --brand:#7c3aed;
      --brand2:#22c55e;
      --line:rgba(255,255,255,.08);
      --shadow:0 20px 60px rgba(0,0,0,.35);
    }
    *{box-sizing:border-box}
    html,body{margin:0;height:100%;font-family:Inter,system-ui,sans-serif;background:radial-gradient(circle at top,#182344 0,#0b1020 55%);color:var(--text)}
    a{text-decoration:none;color:inherit}
    .wrap{min-height:100vh;display:grid;grid-template-columns:1fr 1fr}
    .left{
      padding:40px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      background:
        radial-gradient(circle at 20% 20%, rgba(124,58,237,.25), transparent 25%),
        radial-gradient(circle at 80% 30%, rgba(34,197,94,.15), transparent 22%),
        linear-gradient(180deg, rgba(17,24,45,.65), rgba(11,16,32,.95));
      border-right:1px solid var(--line);
    }
    .logo{display:flex;align-items:center;gap:10px;font-weight:800;letter-spacing:.3px}
    .dot{width:12px;height:12px;border-radius:50%;background:linear-gradient(135deg,var(--brand),#60a5fa);box-shadow:0 0 20px rgba(124,58,237,.9)}
    .hero{
      max-width:520px;
      margin:auto 0;
    }
    .eyebrow{
      display:inline-flex;
      padding:8px 12px;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
      color:#d8dcff;
      font-size:13px;
      margin-bottom:18px;
    }
    h1{
      margin:0;
      font-size:clamp(40px,5vw,68px);
      line-height:.95;
      letter-spacing:-.05em;
    }
    .lead{
      margin:18px 0 0;
      max-width:52ch;
      color:var(--muted);
      line-height:1.7;
      font-size:16px;
    }
    .featuregrid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:14px;
      margin-top:26px;
      max-width:520px;
    }
    .feature{
      padding:16px;
      border-radius:18px;
      background:rgba(255,255,255,.04);
      border:1px solid var(--line);
      color:var(--muted);
    }
    .feature b{display:block;color:var(--text);margin-bottom:6px}
    .right{
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
    }
    .card{
      width:min(440px,100%);
      padding:28px;
      border-radius:28px;
      background:linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
      border:1px solid var(--line);
      box-shadow:var(--shadow);
      backdrop-filter:blur(16px);
    }
    .tabs{
      display:flex;
      gap:10px;
      margin-bottom:22px;
      background:rgba(255,255,255,.04);
      padding:6px;
      border-radius:16px;
      border:1px solid var(--line);
    }
    .tab{
      flex:1;
      text-align:center;
      padding:11px 14px;
      border-radius:12px;
      color:var(--muted);
      font-weight:600;
    }
    .tab.active{
      background:linear-gradient(135deg,var(--brand),#4f46e5);
      color:white;
      box-shadow:0 10px 24px rgba(124,58,237,.28);
    }
    h2{margin:0 0 6px;font-size:28px}
    .sub{margin:0 0 22px;color:var(--muted);line-height:1.6}
    .field{margin-bottom:14px}
    label{display:block;margin:0 0 8px;font-size:14px;color:#d9dfff;font-weight:600}
    input{
      width:100%;
      padding:14px 15px;
      border-radius:14px;
      border:1px solid var(--line);
      background:rgba(10,15,30,.65);
      color:var(--text);
      outline:none;
      transition:.2s ease;
      font-size:15px;
    }
    input:focus{
      border-color:rgba(124,58,237,.6);
      box-shadow:0 0 0 4px rgba(124,58,237,.16);
    }
    .row{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin:12px 0 18px;
      color:var(--muted);
      font-size:14px;
    }
    .remember{
      display:flex;
      align-items:center;
      gap:8px;
    }
    .remember input{width:16px;height:16px;accent-color:var(--brand)}
    .link{color:#c4b5fd}
    .btn{
      width:100%;
      padding:14px 16px;
      border:0;
      border-radius:14px;
      color:white;
      font-weight:700;
      background:linear-gradient(135deg,var(--brand),#4f46e5);
      box-shadow:0 10px 30px rgba(124,58,237,.32);
      cursor:pointer;
      font-size:15px;
    }
    .divider{
      display:flex;
      align-items:center;
      gap:12px;
      margin:20px 0;
      color:var(--muted);
      font-size:13px;
    }
    .divider:before,.divider:after{
      content:"";
      height:1px;
      flex:1;
      background:var(--line);
    }
    .socials{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }
    .social{
      padding:12px 14px;
      border-radius:14px;
      text-align:center;
      border:1px solid var(--line);
      background:rgba(255,255,255,.03);
      color:#e8ecff;
      font-weight:600;
    }
    .bottom{
      margin-top:18px;
      text-align:center;
      color:var(--muted);
      font-size:14px;
      line-height:1.6;
    }
    .bottom a{color:#c4b5fd;font-weight:600}
    @media (max-width: 960px){
      .wrap{grid-template-columns:1fr}
      .left{display:none}
      .right{padding:18px}
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="left">
      <div class="logo"><span class="dot"></span><span>LumoCart</span></div>
      <div class="hero">
        <span class="eyebrow">Premium store access</span>
        <h1>Welcome back to your store.</h1>
        <p class="lead">
          Sign in to manage orders, update products, and access your e-commerce dashboard with a smooth and modern interface.
        </p>
        <div class="featuregrid">
          <div class="feature"><b>Fast login</b>Simple, clean access for returning users.</div>
          <div class="feature"><b>Secure design</b>Professional layout ready for backend integration.</div>
          <div class="feature"><b>Mobile-ready</b>Works beautifully on phones and tablets.</div>
          <div class="feature"><b>Resale friendly</b>Easy to customize for clients.</div>
        </div>
      </div>
      <div style="color:var(--muted);font-size:14px">© 2026 LumoCart</div>
    </section>

    <section class="right">
      <div class="card">
        <div class="tabs">
          <a class="tab active" href="login.html">Login</a>
          <a class="tab" href="#">Sign Up</a>
        </div>

        <h2>Sign in</h2>
        <p class="sub">Enter your details to access the dashboard.</p>

        <form>
          <div class="field">
            <label for="email">Email address</label>
            <input id="email" type="email" placeholder="you@example.com" />
          </div>

          <div class="field">
            <label for="password">Password</label>
            <input id="password" type="password" placeholder="••••••••" />
          </div>

          <div class="row">
            <label class="remember">
              <input type="checkbox" />
              <span>Remember me</span>
            </label>
            <a class="link" href="#">Forgot password?</a>
          </div>

          <button class="btn" type="submit">Login</button>
        </form>

        <div class="divider">or continue with</div>

        <div class="socials">
          <a class="social" href="#">Google</a>
          <a class="social" href="#">GitHub</a>
        </div>

        <div class="bottom">
          Don’t have an account? <a href="#">Create one</a>
        </div>
      </div>
    </section>
  </div>
</body>
</html>
